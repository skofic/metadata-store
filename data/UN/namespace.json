		},
		"_info": {
			"_title": {
				"ISO_639_3_eng": "United Nations"
			},
			"_definition": {
				"ISO_639_3_eng": "Namespace for United Nations organisational and statistical identifiers, including General Assembly regional groups and M.49 geographic region codes."
			},
			"_description": {
				"ISO_639_3_eng": "The United Nations namespace collects identifiers derived from UN systems used to classify countries and territories. Currently it covers two classification schemes: the UN General Assembly regional groups (used for electoral and procedural purposes) and the UN Statistics Division M.49 geographic regions (used for statistical reporting)."
			}
		},
		"_domn": {
			"_term_role": [
				"_term_role_namespace"
			]
		}
	},
	{
		"_code": {
			"_nid": "UN",
			"_lid": "M49",
			"_gid": "UN_M49",
			"_aid": [
				"M49"
			]
		},
		"_info": {
			"_title": {
				"ISO_639_3_eng": "UN M.49 geographic regions"
			},
			"_definition": {
				"ISO_639_3_eng": "Namespace for United Nations Statistics Division M.49 geographic region and sub-region identifiers used for statistical reporting."
			},
			"_description": {
				"ISO_639_3_eng": "The United Nations M.49 standard defines a hierarchy of geographic regions used by the UN Statistics Division for statistical purposes. At the top level are macro-regions (continental groupings such as Africa, Asia, Europe). Each macro-region is subdivided into sub-regions (e.g. Northern Africa, Eastern Asia). Countries and territories are assigned to exactly one sub-region and thereby to one macro-region.\n\nThis namespace holds the macro-region and sub-region terms. The descriptor properties [`UN_Macro-region`](UN_Macro-region.md) and [`UN_Sub-region`](UN_Sub-region.md) reference these enumeration roots."
			}
		},
		"_domn": {
			"_term_role": [
				"_term_role_namespace"
			]
		}
	},
